# ============================================
# База данных
# ============================================
# PostgreSQL connection string
# Формат: postgresql://username:password@host:port/database
# Пример для локальной разработки:
DATABASE_URL="postgresql://user:celnumog1@localhost:5432/ai_platform"

# ============================================
# NextAuth.js v5 (Аутентификация)
# ============================================
# URL вашего приложения (для продакшена укажите реальный домен)
AUTH_URL="http://localhost:3000"
# Секретный ключ для подписи токенов (обязательно!)
# Сгенерируйте через: openssl rand -base64 32
# Или на Windows PowerShell: -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 32 | ForEach-Object {[char]})
AUTH_SECRET="IM6CUBehZV1i0nl2FdR3caOSWX8jTtH9"

# Для обратной совместимости (NextAuth v4)
# Можно оставить пустыми, если используете только AUTH_URL и AUTH_SECRET
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="IM6CUBehZV1i0nl2FdR3caOSWX8jTtH9"

# ============================================
# Google OAuth (опционально)
# ============================================
# Получите в Google Cloud Console: https://console.cloud.google.com/
# Создайте OAuth 2.0 Client ID и добавьте redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="1024578853768-el77m1mddsgpeqb5sg7d6hinh22l69r0.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="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"

# ============================================
# AI APIs (для генерации изображений)
# ============================================
# Replicate API Token
# Получите на: https://replicate.com/account/api-tokens
# Формат токена: r8_...
REPLICATE_API_TOKEN="your-replicate-api-token"

# OpenAI API Key
# Получите на: https://platform.openai.com/api-keys
# Формат ключа: sk-...
OPENAI_API_KEY="your-openai-api-key"

# ============================================
# Платежи - ЮKassa (опционально)
# ============================================
# Получите в личном кабинете ЮKassa: https://yookassa.ru/
YOOKASSA_SHOP_ID="your-shop-id"
YOOKASSA_SECRET_KEY="your-yookassa-secret-key"

# ============================================
# Хранилище - Cloudinary (опционально)
# ============================================
# Для загрузки и хранения изображений
# Получите на: https://cloudinary.com/
# NEXT_PUBLIC_* переменные доступны в браузере (клиентский код)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
